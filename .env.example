# Voor de basis-app zijn GEEN server-secrets nodig: iedere gebruiker vult zelf
# zijn geboortedatum, loonschaal en iCal-link in (alleen in de browser).
#
# OPTIONEEL — alleen nodig voor de "bewaar je geschiedenis"-account-functie
# (Firebase). Laat je deze leeg, dan verbergt de app de account-knoppen en
# bewaart hij voorbije periodes alleen in localStorage op dit apparaat.
#
# Deze waarden zijn GÉÉN geheim: de Firebase web-config staat sowieso in de
# client-bundel. De beveiliging zit in firestore.rules (alleen je eigen data).
# Haal ze op uit de Firebase Console → Project settings → "Je apps" → Web-app.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
