# Kopieer naar .env.local en vul in (deze waarden NOOIT in GitHub zetten)

# Je rooster-iCal van personeelstool (de hele URL incl. ?hash=...)
ICAL_URL=

# Het wachtwoord waarmee je inlogt
APP_PASSWORD=

# Willekeurige geheime sleutel voor het ondertekenen van je login
# Genereer met: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
