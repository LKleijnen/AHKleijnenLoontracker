rules_version = '2';

// Beveiliging voor de "bewaar je geschiedenis"-functie.
// Elke gebruiker mag uitsluitend bij zijn eigen gegevens onder zijn eigen uid:
// het profiel-document (instellingen) én alles in de subcollecties (diensten).
// Plak deze regels in Firebase Console → Firestore Database → Rules → Publiceren.
service cloud.firestore {
  match /databases/{database}/documents {
    match /gebruikers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
